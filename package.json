{
  "name": "movie-chat",
  "version": "2.1.0",
  "description": "AI-powered movie recommendations with Plex integration",
  "author": "nookied",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "next lint",
    "setup": "bash setup.sh",
    "update": "bash update.sh",
    "uninstall:app": "bash uninstall.sh",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder --mac",
    "release": "npm run build && electron-builder --mac --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "next": "^15.5.12",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "overrides": {
    "glob": ">=10.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.12",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
