# ─── OpenRouter (primary LLM) ────────────────────────────────────────────────
# Free tier available — sign up at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Leave blank to use the default free model (auto-routed)
OPENROUTER_MODEL=

# ─── Ollama (local LLM fallback) ─────────────────────────────────────────────
# Optional — used automatically when OpenRouter is unavailable.
# Install from https://ollama.com, then run: ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── Plex ────────────────────────────────────────────────────────────────────
# Your Plex server URL (usually http://localhost:32400 or http://IP:32400)
PLEX_BASE_URL=http://localhost:32400
# Get your token: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=your_plex_token_here

# ─── TMDB (The Movie Database) ───────────────────────────────────────────────
# Free API key: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ─── OMDB (includes IMDb + Rotten Tomatoes scores) ───────────────────────────
# Free API key (1000 req/day): https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# ─── Transmission ─────────────────────────────────────────────────────────────
# Transmission RPC URL (default port is 9091)
TRANSMISSION_BASE_URL=http://localhost:9091
# Leave blank if Transmission has no authentication
TRANSMISSION_USERNAME=
TRANSMISSION_PASSWORD=
# Absolute path to where Transmission downloads files
TRANSMISSION_DOWNLOAD_DIR=/Users/yourname/Downloads/Torrents

# ─── File Management ──────────────────────────────────────────────────────────
# Absolute path to your Plex movie library on the external drive
LIBRARY_DIR=/Volumes/ExternalDrive/Movies
